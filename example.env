# Locale — match your system (run `locale` to check)
LANG=en_US.UTF-8
LANGUAGE=en_US:en
LC_ALL=en_US.UTF-8

# Timezone — see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Your Samsung TV's IP address on the local network
TV_IP=192.168.1.x

# Password used for both the author and distributor Samsung certificates
# (choose "Apply the same password for the distributor certificate" when creating them)
CERT_PASSWORD=your_certificate_password

# Jellyfin release branches to build
# See https://github.com/jellyfin/jellyfin-tizen/branches and https://github.com/jellyfin/jellyfin-web/branches
JELLYFIN_TIZEN_RELEASE=master
JELLYFIN_WEB_RELEASE=release-10.11.z

# Tizen Studio version (5.5 recommended — 6.0 has known issues)
TIZEN_STUDIO_VERSION=5.5
